# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Path to service account JSON key (download from GCP Console in Task 9)
GOOGLE_APPLICATION_CREDENTIALS=service-account-key.json

# Gemini API key — get free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# OpenAI API key — get at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Data source API keys (obtain in Plan 2)
# Reddit: create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=crypto-edge-ingestion/0.1
# CryptoPanic: register at https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=your-cryptopanic-api-key

# Adapter modes
# WAREHOUSE_MODE: bigquery | duckdb
WAREHOUSE_MODE=duckdb
# LLM_MODE: gemini | openai
LLM_MODE=openai

# Local DuckDB path (used when WAREHOUSE_MODE=duckdb)
DUCKDB_PATH=data/local.duckdb
